# =============================================================================
# aegis-phase1 environment configuration
# Copy this file to `.env` and fill in the values
# =============================================================================

# --- Ollama LLM (required) ---
OLLAMA_BASE_URL=http://localhost:11434
# Phase 1 v1.2 default model (per implementation contract)
OLLAMA_MODEL=gemma4:e2b
# OLLAMA_CONTEXT=4096    # Optional: token context window (default inferred)

# --- Phase 1 Pipeline ---
MOCK_LLM=false

# --- Langfuse tracing (optional, opt-in) ---
LANGFUSE_ENABLED=false
LANGFUSE_PUBLIC_KEY=pk-lf-CHANGEME
LANGFUSE_SECRET_KEY=sk-lf-CHANGEME
LANGFUSE_BASE_URL=http://localhost:3000
