# AEGIS-Phase1 canonical .env (no credentials, safe to commit).
# Override with a real .env (gitignored) for actual runs.
#
# CORR-042 (2026-07-21): gemma4:e2b is the canonical Phase 1 model.
# The RobustParser 5-strategy fallback was tuned for gemma4:e2b's
# known format bugs. Do NOT switch to e4b or other variants without
# re-validating the parser.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma4:e2b
MOCK_LLM=false
LANGFUSE_ENABLED=false
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=http://localhost:3000
