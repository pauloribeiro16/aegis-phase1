# AEGIS-Phase1 canonical .env (no credentials, safe to commit).
# Override with a real .env (gitignored) for actual runs.
#
# CORR-056 (2026-07-23): gemma4:e4b is the canonical Phase 1 model.
# The RobustParser 5-strategy fallback works for both gemma4:e2b and
# gemma4:e4b outputs (they share the same architecture and known
# format quirks). To pin to e2b instead, set OLLAMA_MODEL=gemma4:e2b
# in your local .env (gitignored).
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma4:e4b
MOCK_LLM=false
LANGFUSE_ENABLED=false
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=http://localhost:3000

# CORR-056 (2026-07-23): HuggingFace transformers provider (opt-in).
# Set LLM_PROVIDER=transformers to use a HF model instead of Ollama.
# Set HF_MODEL to the HF Hub id (e.g. google/gemma-4-E2B-it).
# Set HF_HOME to a path with enough space (model cache is ~5-10GB per model).
LLM_PROVIDER=ollama          # ollama | transformers
HF_MODEL=google/gemma-4-E2B-it
HF_HOME=/media/epmq-cyber/191a70fe-626c-409b-a8ca-caed8a953c33/hf_cache
